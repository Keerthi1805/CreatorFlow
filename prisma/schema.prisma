generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CREATOR
  BRAND
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum CollabStatus {
  PENDING
  ACCEPTED
  REJECTED
  NEGOTIATING
  CANCELLED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  SAMPLE_REQUESTED
  SAMPLE_UPLOADED
  SAMPLE_APPROVED
  SAMPLE_REJECTED
  IN_PRODUCTION
  PRODUCTION_25
  PRODUCTION_50
  PRODUCTION_75
  PRODUCTION_COMPLETE
  QUALITY_CHECK
  PACKAGING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum SampleStatus {
  REQUESTED
  UPLOADED
  APPROVED
  REJECTED
  MODIFICATION_REQUESTED
}

enum PaymentStatus {
  PENDING
  ADVANCE_PAID
  PARTIALLY_PAID
  PAID
  OVERDUE
  REFUNDED
}

enum ShipmentStatus {
  PENDING
  DISPATCHED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
}

enum NotifType {
  COLLAB_REQUEST
  COLLAB_ACCEPTED
  COLLAB_REJECTED
  ORDER_CREATED
  ORDER_CONFIRMED
  SAMPLE_REQUESTED
  SAMPLE_UPLOADED
  SAMPLE_APPROVED
  SAMPLE_REJECTED
  PRODUCTION_UPDATE
  SHIPMENT_DISPATCHED
  SHIPMENT_DELIVERED
  PAYMENT_RELEASED
  PAYMENT_DUE
  GENERAL
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
  CANCELLED
}

model User {
  id                 String             @id @default(cuid())
  clerkId            String             @unique
  email              String             @unique
  name               String
  role               UserRole
  avatarUrl          String?
  phone              String?
  verificationStatus VerificationStatus @default(PENDING)
  onboarded          Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  creatorProfile CreatorProfile?
  brandProfile   BrandProfile?
  notifications  Notification[]

  @@index([clerkId])
  @@index([role])
}

model CreatorProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  businessName       String
  ownerName          String
  gstNumber          String?
  location           String?
  city               String
  state              String
  pincode            String?
  phone              String?
  productionCapacity Int      @default(0)
  experienceYears    Int      @default(0)
  categories         String[]
  portfolioImages    String[]
  bio                String?
  bankAccount        String?
  ifscCode           String?
  totalRevenue       Float    @default(0)
  totalOrders        Int      @default(0)
  completedOrders    Int      @default(0)
  rating             Float    @default(0)
  reviewCount        Int      @default(0)
  onTimeDelivery     Float    @default(0)
  acceptanceRate     Float    @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  collabRequests CollabRequest[] @relation("CreatorCollabs")
  orders         Order[]         @relation("CreatorOrders")

  @@index([userId])
}

model BrandProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String
  brandLogoUrl   String?
  gstNumber      String?
  contactPerson  String
  phone          String?
  website        String?
  categories     String[]
  totalSpend     Float    @default(0)
  totalOrders    Int      @default(0)
  activeCreators Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouses     Warehouse[]
  collabRequests CollabRequest[] @relation("BrandCollabs")
  orders         Order[]         @relation("BrandOrders")

  @@index([userId])
}

model Product {
  id               String   @id @default(cuid())
  creatorId        String
  name             String
  category         String
  description      String
  images           String[]
  materials        String[]
  pricePerUnit     Float
  minOrderQty      Int
  maxCapacity      Int
  leadTimeDays     Int
  customBranding   Boolean  @default(false)
  packagingOptions String[]
  certifications   String[]
  inStock          Boolean  @default(true)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creator    CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([creatorId])
  @@index([category])
}

model Warehouse {
  id             String   @id @default(cuid())
  brandId        String
  name           String
  address        String
  city           String
  state          String
  pincode        String
  contactPerson  String
  phone          String
  operatingHours String?
  instructions   String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  brand  BrandProfile @relation(fields: [brandId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([brandId])
}

model CollabRequest {
  id                   String       @id @default(cuid())
  brandId              String
  creatorId            String
  initiatedBy          UserRole     @default(BRAND)
  status               CollabStatus @default(PENDING)
  message              String?
  requirements         String?
  expectedVolume       Int?
  expectedRevenue      Float?
  timeline             String?
  brandingInstructions String?
  creatorResponse      String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  brand   BrandProfile   @relation("BrandCollabs", fields: [brandId], references: [id])
  creator CreatorProfile @relation("CreatorCollabs", fields: [creatorId], references: [id])

  @@index([brandId])
  @@index([creatorId])
  @@index([status])
}

model Order {
  id                    String        @id @default(cuid())
  orderNumber           String        @unique
  brandId               String
  creatorId             String
  warehouseId           String?
  status                OrderStatus   @default(DRAFT)
  paymentStatus         PaymentStatus @default(PENDING)
  totalAmount           Float
  advanceAmount         Float         @default(0)
  advancePaid           Float         @default(0)
  finalAmount           Float         @default(0)
  finalPaid             Float         @default(0)
  commissionAmount      Float         @default(0)
  colorVariants         String[]
  materialRequirements  String?
  packagingInstructions String?
  privateLabelRequired  Boolean       @default(false)
  brandLogoRequired     Boolean       @default(false)
  shippingInstructions  String?
  deliveryDeadline      DateTime?
  confirmedAt           DateTime?
  productionStartedAt   DateTime?
  shippedAt             DateTime?
  deliveredAt           DateTime?
  completedAt           DateTime?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  brand          BrandProfile    @relation("BrandOrders", fields: [brandId], references: [id])
  creator        CreatorProfile  @relation("CreatorOrders", fields: [creatorId], references: [id])
  warehouse      Warehouse?      @relation(fields: [warehouseId], references: [id])
  items          OrderItem[]
  samples        Sample[]
  shipments      Shipment[]
  payments       Payment[]
  productionLogs ProductionLog[]
  activityLogs   ActivityLog[]

  @@index([brandId])
  @@index([creatorId])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Sample {
  id          String       @id @default(cuid())
  orderId     String
  status      SampleStatus @default(REQUESTED)
  images      String[]
  notes       String?
  brandNotes  String?
  requestedAt DateTime     @default(now())
  uploadedAt  DateTime?
  reviewedAt  DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ProductionLog {
  id         String      @id @default(cuid())
  orderId    String
  stage      OrderStatus
  percentage Int         @default(0)
  notes      String?
  createdAt  DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Shipment {
  id               String         @id @default(cuid())
  orderId          String
  status           ShipmentStatus @default(PENDING)
  courier          String?
  trackingNumber   String?
  dispatchDate     DateTime?
  expectedDelivery DateTime?
  actualDelivery   DateTime?
  weight           Float?
  dimensions       String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  amount        Float
  type          String
  status        PaymentStatus @default(PENDING)
  method        String?
  transactionId String?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      NotifType
  title     String
  message   String
  link      String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model ActivityLog {
  id          String   @id @default(cuid())
  orderId     String?
  userId      String?
  action      String
  description String
  createdAt   DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Contract {
  id         String         @id @default(cuid())
  brandId    String
  creatorId  String
  orderId    String?
  title      String
  fileUrl    String?
  status     ContractStatus @default(DRAFT)
  value      Float?
  signedAt   DateTime?
  expiryDate DateTime?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([brandId])
  @@index([creatorId])
}
