# IMPORTANT: If password has @ symbol, encode it as %40
# Example: Pass@123 becomes Pass%40123
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/craftflow"

# Get from dashboard.clerk.com -> your app -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

NEXT_PUBLIC_APP_URL=http://localhost:3000
